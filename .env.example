# Neon Postgres — https://neon.tech
# Prisma 7: URL configurada em prisma.config.ts (carrega este .env via dotenv)
# Dashboard → seu projeto → Connect → copie a connection string
#
# Desenvolvimento e migrations: use a URL **direta** (host ep-xxx, sem "-pooler")
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=verify-full"
#
# Produção (Vercel): pode usar a URL com **-pooler** no host para mais conexões
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=verify-full"
#
# Migrations (Vercel build / local): URL direta sem "-pooler" — ou deixe o script derivar da DATABASE_URL
# DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=verify-full"

# Sessão de login (mín. 16 caracteres — gere uma string aleatória)
AUTH_SECRET=troque-por-uma-chave-secreta-longa

# Opcional: feedback detalhado com GPT (estrutura, fraseologia, sugestões)
OPENAI_API_KEY=sk-...

# Azure Speech — pronúncia real (Pronunciation Assessment)
# Portal: https://portal.azure.com → Create resource → Speech
AZURE_SPEECH_KEY=sua-chave-azure
AZURE_SPEECH_REGION=eastus

# Captain Delta voice (TTS). Default: enabled. Set to false for text-only coaching.
# NEXT_PUBLIC_CAPTAIN_DELTA_VOICE_ENABLED=true

# Vercel Blob — áudios das gravações (produção na Vercel)
# Dashboard → Storage → Blob → Create → copie o token Read/Write
# Em dev sem token, os áudios vão para data/recordings/
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Opcional: pasta local quando BLOB_READ_WRITE_TOKEN não está definido
# RECORDINGS_DIR=/caminho/absoluto/recordings
