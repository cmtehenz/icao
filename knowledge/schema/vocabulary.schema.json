{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://icao-delta.local/knowledge/schema/vocabulary.schema.json",
  "title": "ICAO Delta Vocabulary Knowledge Entry",
  "type": "object",
  "required": [
    "id",
    "term",
    "category",
    "level",
    "meaning",
    "simpleMeaning",
    "portugueseMeaning",
    "operationalMeaning",
    "whoUsesIt",
    "whenUsed",
    "whyUsed",
    "realExamples",
    "pilotResponses",
    "icaoQuestions",
    "commonMistakes",
    "pronunciationTips",
    "relatedTerms",
    "compareTerms",
    "didYouKnow",
    "references",
    "lastReviewed",
    "version"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "term": { "type": "string", "minLength": 1 },
    "category": { "type": "string", "minLength": 1 },
    "level": { "type": "integer", "minimum": 1, "maximum": 5 },
    "meaning": { "type": "string", "minLength": 1 },
    "simpleMeaning": { "type": "string", "minLength": 1 },
    "portugueseMeaning": { "type": "string", "minLength": 1 },
    "operationalMeaning": { "type": "string", "minLength": 1 },
    "whoUsesIt": { "type": "string", "minLength": 1 },
    "whenUsed": { "type": "string", "minLength": 1 },
    "whyUsed": { "type": "string", "minLength": 1 },
    "realExamples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["text", "context"],
        "properties": {
          "text": { "type": "string", "minLength": 1 },
          "context": {
            "type": "string",
            "enum": [
              "tower",
              "ground",
              "approach",
              "departure",
              "center",
              "pilot",
              "passenger-briefing",
              "crm",
              "checklist",
              "emergency",
              "weather",
              "navigation"
            ]
          },
          "speaker": { "type": "string" }
        }
      }
    },
    "pilotResponses": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "icaoQuestions": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "commonMistakes": { "type": "array", "items": { "type": "string" } },
    "pronunciationTips": { "type": "array", "items": { "type": "string" } },
    "relatedTerms": { "type": "array", "items": { "type": "string" } },
    "compareTerms": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["term", "note"],
        "properties": {
          "term": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    },
    "didYouKnow": { "type": "array", "items": { "type": "string" } },
    "captainStory": { "type": "string" },
    "references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "source"],
        "properties": {
          "title": { "type": "string" },
          "source": {
            "type": "string",
            "enum": [
              "icao-delta",
              "icao",
              "faa",
              "faa-aim",
              "faa-phak",
              "skybrary",
              "easa",
              "rotorcraft",
              "icao-phraseology",
              "youglish"
            ]
          },
          "url": { "type": "string", "format": "uri" },
          "attribution": { "type": "string" }
        }
      }
    },
    "lastReviewed": { "type": "string", "format": "date" },
    "version": { "type": "string", "minLength": 1 }
  }
}
