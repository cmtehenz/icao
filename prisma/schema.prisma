generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  vaultWords   VaultWord[]
  evaluations  Evaluation[]
  studyDays    StudyDay[]
}

model VaultWord {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  word            String
  lowestAccuracy  Int
  lastAccuracy    Int
  errorType       String
  errorLabel      String
  context         String    @default("")
  timesSeen       Int       @default(1)
  practiceCount   Int       @default(0)
  lastSeenAt      DateTime
  lastPracticedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, word])
  @@index([userId])
}

model Evaluation {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type               String
  question           String
  transcript         String
  overallScore       Int
  structureScore     Int
  contentScore       Int
  phraseologyScore   Int
  pronunciationScore Int
  icaoLevel          Int?
  icaoCriteria       String?
  summary            String   @default("")
  audioKey           String?
  createdAt          DateTime @default(now())

  @@index([userId, createdAt])
}

model StudyDay {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date         DateTime @db.Date
  part1Seconds Int      @default(0)
  part2Seconds Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
}
